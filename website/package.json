{
  "name": "sitelytics-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server/dev.ts",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build:fastify": "tsc -p tsconfig.server.json",
    "build": "pnpm build:client && pnpm build:server && pnpm build:fastify",
    "start": "NODE_ENV=production node dist/fastify/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/middie": "^9.0.2",
    "@fastify/static": "^8.0.4",
    "fastify": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
